<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>סימולטור מכונת מזל - דו לשוני</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Arimo:wght@700&family=Monoton&family=Fira+Code&display=swap');
        
        body {
            font-family: 'Arimo', sans-serif;
            background-color: #020617;
            color: white;
            overflow-x: hidden;
        }

        .code-font { font-family: 'Fira Code', monospace; }

        .machine-body {
            background: linear-gradient(145deg, #b91c1c, #7f1d1d);
            border: 12px solid #facc15;
            box-shadow: 0 0 50px rgba(0,0,0,0.8), inset 0 0 20px rgba(255,255,255,0.2);
            border-radius: 60px 60px 20px 20px;
        }

        .reel {
            width: 85px;
            height: 130px;
            background: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 56px;
            font-weight: 900;
            color: #1e293b;
            box-shadow: inset 0 0 25px rgba(0,0,0,0.6);
            overflow: hidden;
            position: relative;
            transition: all 0.1s;
        }

        .spinning {
            filter: blur(6px);
            transform: scale(0.92);
            opacity: 0.8;
        }

        .lever-container {
            width: 40px;
            height: 200px;
            background: #334155;
            border-radius: 20px;
            position: absolute;
            right: -55px;
            top: 60px;
            display: flex;
            flex-direction: column;
            align-items: center;
            border: 4px solid #1e293b;
            cursor: pointer;
        }

        .lever-rod {
            width: 12px;
            height: 120px;
            background: linear-gradient(to right, #94a3b8, #cbd5e1);
            border-radius: 10px;
            transition: height 0.2s ease-in-out;
        }

        .lever-knob {
            width: 55px;
            height: 55px;
            background: radial-gradient(circle, #ef4444, #7f1d1d);
            border-radius: 50%;
            box-shadow: 0 8px 15px rgba(0,0,0,0.6);
            transition: transform 0.2s ease-in-out;
        }

        .lever-active .lever-rod { height: 40px; }
        .lever-active .lever-knob { transform: translateY(80px); }

        .light {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            animation: flash 0.5s infinite alternate;
        }

        @keyframes flash {
            from { opacity: 0.3; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1.1); box-shadow: 0 0 10px currentColor; }
        }

        .debug-row {
            border-bottom: 1px solid #1e293b;
            padding: 10px 0;
        }

        /* Modal Styles */
        .modal-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(4px);
            z-index: 50;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #0f172a;
            border: 2px solid #334155;
            border-radius: 24px;
            width: 90%;
            max-width: 500px;
            max-height: 80vh;
            overflow-y: auto;
            padding: 24px;
            box-shadow: 0 0 40px rgba(0,0,0,1);
        }
    </style>
</head>
<body class="flex flex-col lg:flex-row min-h-screen">

    <!-- פאנל ניטור בלבד - דו לשוני -->
    <div class="w-full lg:w-1/3 p-6 bg-slate-900 border-l border-slate-800 order-2 lg:order-1 flex flex-col">
        <div class="mb-4">
            <h2 class="text-2xl font-bold text-yellow-400">ניטור אקראיות 🔍</h2>
            <h2 class="text-lg font-bold text-yellow-400/80 tracking-tight" dir="rtl">مراقبة العشوائية</h2>
        </div>
        
        <div id="debug-container" class="space-y-2 flex-grow overflow-y-auto">
            <div class="debug-row">
                <div class="flex justify-between text-[10px] uppercase font-bold">
                    <span class="text-pink-500">גלגל א'</span>
                    <span class="text-pink-500">العجلة أ</span>
                </div>
                <div class="flex justify-between items-center mt-1">
                    <span id="raw-1" class="code-font text-xs text-slate-400">0.00000000</span>
                    <span id="res-1" class="text-xl font-bold text-yellow-500">0</span>
                </div>
            </div>
            <div class="debug-row">
                <div class="flex justify-between text-[10px] uppercase font-bold">
                    <span class="text-cyan-500">גלגל ב'</span>
                    <span class="text-cyan-500">العجلة ب</span>
                </div>
                <div class="flex justify-between items-center mt-1">
                    <span id="raw-2" class="code-font text-xs text-slate-400">0.00000000</span>
                    <span id="res-2" class="text-xl font-bold text-yellow-500">0</span>
                </div>
            </div>
            <div class="debug-row">
                <div class="flex justify-between text-[10px] uppercase font-bold">
                    <span class="text-purple-500">גלגל ג'</span>
                    <span class="text-purple-500">العجلة ج</span>
                </div>
                <div class="flex justify-between items-center mt-1">
                    <span id="raw-3" class="code-font text-xs text-slate-400">0.00000000</span>
                    <span id="res-3" class="text-xl font-bold text-yellow-500">0</span>
                </div>
            </div>
        </div>
    </div>

    <!-- המכונה הוויזואלית -->
    <div class="flex-1 flex flex-col items-center justify-center p-4 order-1 lg:order-2 bg-[#020617]">
        <div class="relative flex items-center">
            
            <!-- כפתור טבלת תוצאות - מלבני, גדול יותר ובצד שמאל -->
            <div class="absolute -left-36 top-1/2 -translate-y-1/2 flex flex-col items-center">
                <button id="history-btn" class="bg-gradient-to-b from-blue-600 to-indigo-700 hover:from-blue-500 hover:to-indigo-600 text-white px-6 py-4 rounded-2xl shadow-2xl transition-all transform active:scale-95 flex flex-col items-center justify-center border-4 border-slate-900 shadow-blue-500/30 min-w-[120px]">
                    <span class="text-sm font-bold leading-tight whitespace-nowrap">טבלת תוצאות</span>
                    <span class="text-[10px] font-medium leading-tight mt-1" dir="rtl">جدول النتائج</span>
                </button>
            </div>

            <div class="relative">
                <div class="flex justify-center gap-4 mb-4">
                    <div class="light text-yellow-400 bg-yellow-400"></div>
                    <div class="light text-red-500 bg-red-500" style="animation-delay: 0.1s"></div>
                    <div class="light text-blue-500 bg-blue-500" style="animation-delay: 0.2s"></div>
                    <div class="light text-green-500 bg-green-500" style="animation-delay: 0.3s"></div>
                </div>

                <div class="machine-body p-8 lg:p-12 relative max-w-sm">
                    <div class="text-center mb-8">
                        <h1 style="font-family: 'Monoton', cursive;" class="text-4xl text-white drop-shadow-2xl">LUCKY</h1>
                        <div class="text-[10px] text-yellow-300 font-bold tracking-[0.4em] uppercase mt-2">True Random Engine</div>
                    </div>

                    <div class="bg-black/90 p-4 rounded-3xl border-4 border-slate-900 flex gap-3 mb-8 shadow-inner">
                        <div id="reel1" class="reel">0</div>
                        <div id="reel2" class="reel">0</div>
                        <div id="reel3" class="reel">0</div>
                    </div>

                    <div id="status-msg" class="bg-slate-950 text-blue-400 font-mono text-center py-2 rounded-lg border border-blue-900/30 mb-8 text-xs leading-relaxed">
                        לחצו להגרלה<br>إضغط للسحب
                    </div>

                    <button id="spin-btn" class="w-full bg-gradient-to-b from-yellow-400 to-yellow-600 hover:from-yellow-300 hover:to-yellow-500 text-black font-black py-4 rounded-2xl border-b-8 border-yellow-800 active:border-b-0 active:translate-y-2 transition-all shadow-xl flex flex-col items-center justify-center">
                        <span class="text-2xl">הגרל!</span>
                        <span class="text-sm font-bold">إبدأ!</span>
                    </button>

                    <div id="lever" class="lever-container hidden md:flex">
                        <div class="lever-rod"></div>
                        <div class="lever-knob"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Results History -->
    <div id="history-modal" class="modal-backdrop">
        <div class="modal-content">
            <div class="flex justify-between items-center mb-6 border-b border-slate-700 pb-4">
                <div>
                    <h3 class="text-xl font-bold text-white">טבלת תוצאות</h3>
                    <h4 class="text-sm text-slate-400" dir="rtl">سجل النتائج</h4>
                </div>
                <button id="close-modal" class="text-slate-400 hover:text-white text-2xl font-bold">&times;</button>
            </div>
            
            <div id="history-list" class="space-y-3">
                <p class="text-center text-slate-500 py-8">אין היסטוריה עדיין...<br>לא يوجد سجل بعد...</p>
            </div>
            
            <button id="clear-history" class="w-full mt-6 py-3 text-sm font-bold text-red-400 hover:text-red-300 transition-colors uppercase tracking-widest border border-red-900/30 rounded-xl flex flex-col items-center">
                <span>נקה היסטוריה</span>
                <span class="text-[10px] mt-1" dir="rtl">مسح السجل</span>
            </button>
        </div>
    </div>

    <script>
        let isSpinning = false;
        let history = [];
        
        const reels = [document.getElementById('reel1'), document.getElementById('reel2'), document.getElementById('reel3')];
        const debugRaw = [document.getElementById('raw-1'), document.getElementById('raw-2'), document.getElementById('raw-3')];
        const debugRes = [document.getElementById('res-1'), document.getElementById('res-2'), document.getElementById('res-3')];
        const statusMsg = document.getElementById('status-msg');
        const spinBtn = document.getElementById('spin-btn');
        const lever = document.getElementById('lever');
        const historyBtn = document.getElementById('history-btn');
        const historyModal = document.getElementById('history-modal');
        const closeModal = document.getElementById('close-modal');
        const historyList = document.getElementById('history-list');
        const clearHistoryBtn = document.getElementById('clear-history');

        async function startSpin() {
            if (isSpinning) return;
            isSpinning = true;
            spinBtn.disabled = true;
            lever.classList.add('lever-active');
            setTimeout(() => lever.classList.remove('lever-active'), 400);

            statusMsg.innerHTML = "מגריל...<br>جاري السحب...";
            const spinPromises = reels.map((reel, index) => animateReel(reel, index));
            const results = await Promise.all(spinPromises);
            
            const isJackpot = results.every(v => v === results[0]);
            
            // Add to history
            const time = new Date().toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            history.unshift({ results: [...results], isJackpot, time });
            if (history.length > 50) history.pop();

            if (isJackpot) {
                statusMsg.innerHTML = "JACKPOT!<br>فوز ساحق!";
                statusMsg.className = "bg-green-900/30 text-green-400 font-bold text-center py-2 rounded-lg border border-green-500 mb-8 animate-bounce";
            } else {
                statusMsg.innerHTML = "נסו שוב!<br>حاول مرة أخرى!";
                statusMsg.className = "bg-slate-950 text-slate-500 font-mono text-center py-2 rounded-lg border border-slate-900 mb-8 text-xs";
            }
            
            isSpinning = false;
            spinBtn.disabled = false;
        }

        function animateReel(reel, index) {
            return new Promise(resolve => {
                let startTime = Date.now();
                const duration = 1500 + (index * 800);
                reel.classList.add('spinning');
                const interval = setInterval(() => {
                    const val = Math.random();
                    const digit = Math.floor(val * 10);
                    reel.innerText = digit;
                    debugRaw[index].innerText = val.toFixed(8);
                    debugRes[index].innerText = digit;
                    if (Date.now() - startTime >= duration) {
                        clearInterval(interval);
                        reel.classList.remove('spinning');
                        resolve(digit);
                    }
                }, 70);
            });
        }

        function updateHistoryUI() {
            if (history.length === 0) {
                historyList.innerHTML = '<p class="text-center text-slate-500 py-8">אין היסטוריה עדיין...<br>לא يوجد سجل بعد...</p>';
                return;
            }

            historyList.innerHTML = history.map((item, idx) => `
                <div class="flex justify-between items-center p-3 rounded-xl ${item.isJackpot ? 'bg-green-950/40 border border-green-500/30' : 'bg-slate-800/40 border border-slate-700/50'}">
                    <div class="flex gap-2">
                        ${item.results.map(num => `<span class="w-8 h-8 flex items-center justify-center bg-white text-slate-900 rounded font-bold">${num}</span>`).join('')}
                    </div>
                    <div class="text-right">
                        <div class="text-[10px] text-slate-500 code-font">${item.time}</div>
                        ${item.isJackpot ? '<div class="text-[10px] text-green-400 font-bold uppercase">JACKPOT</div>' : ''}
                    </div>
                </div>
            `).join('');
        }

        // Event Listeners
        spinBtn.addEventListener('click', startSpin);
        lever.addEventListener('click', startSpin);
        
        historyBtn.addEventListener('click', () => {
            updateHistoryUI();
            historyModal.style.display = 'flex';
        });

        closeModal.addEventListener('click', () => historyModal.style.display = 'none');
        
        window.addEventListener('click', (e) => {
            if (e.target === historyModal) historyModal.style.display = 'none';
        });

        clearHistoryBtn.addEventListener('click', () => {
            history = [];
            updateHistoryUI();
        });
    </script>
</body>
</html>
